{
  "name": "ffc-pay-automation",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "cypress:local": "cypress open --e2e --browser chrome --env env=local,TAGS=@local",
    "cypress:dev": "cypress open --e2e --browser chrome --env env=dev,TAGS=@dev",
    "cypress:test": "cypress open --e2e --browser=chrome --env env=test,TAGS=@test",
    "cypress:local:all": "cypress run --env env=local,TAGS=@local --browser chrome",
    "cypress:dev:all": "cypress run --env env=dev,TAGS=@dev --browser chrome",
    "cypress:test:all": "cypress run --env env=test,TAGS=@test --browser chrome",
    "cypress:local:one": "cypress run --env env=local,TAGS=@local --spec",
    "cypress:dev:one": "cypress run --env env=dev,TAGS=@dev --spec",
    "cypress:test:one": "cypress run --env env=test,TAGS=@test --spec",
    "report:merge": "mochawesome-merge cypress/reports/mocha/mochawesome*.json > cypress/reports/mocha/output.json",
    "report:html": "marge cypress/reports/mocha/output.json --reportDir cypress/reports/mocha --reportFilename index && node cypress/utils/hidePendingInHtml.js cypress/reports/mocha/index.html",
    "clean:reports": "powershell -Command \"Remove-Item -Recurse -Force cypress/reports/mocha/*; Remove-Item -Recurse -Force cypress/downloads/*; Remove-Item -Recurse -Force cypress/screenshots/*; Remove-Item -Recurse -Force cypress/videos/*\""
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^15.1.5",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@cucumber/cucumber": "^7.3.2",
    "@cucumber/message-streams": "^4.0.1",
    "@cucumber/messages": "^32.2.0",
    "axe-core": "^4.11.0",
    "cypress": "^12.17.4",
    "cypress-axe": "^1.7.0",
    "cypress-dotenv": "^3.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-cucumber": "^2.0.0",
    "eslint-plugin-cypress": "^6.3.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "jsonc-eslint-parser": "^3.1.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.2.2",
    "mochawesome-report-generator": "^6.2.0"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/e2e/steps/**/*.js"
    ]
  },
  "dependencies": {
    "@azure/service-bus": "^7.9.0",
    "@azure/storage-blob": "^12.15.0",
    "csv-parse": "^5.5.0",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.0.3",
    "fs-extra": "^11.1.1",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.1"
  }
}